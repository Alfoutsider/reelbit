# ── Solana ────────────────────────────────────────────────────────────────────
RPC_URL=https://api.devnet.solana.com

# ── Keypair (choose one) ──────────────────────────────────────────────────────
# Production (Render): paste JSON array of secret key bytes
MIGRATION_KEYPAIR_JSON=

# Local dev: path to your Solana keypair file
MIGRATION_KEYPAIR_PATH=/home/user/.config/solana/id.json

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
SERVER_BASE_URL=http://localhost:3001
DATA_DIR=./data

# ── Auth / API keys ───────────────────────────────────────────────────────────
INTERNAL_API_SECRET=dev-secret-change-in-prod
ADMIN_API_KEY=admin-dev-key
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=

# ── Cloudflare Turnstile (bot protection) ─────────────────────────────────────
# Get from: https://dash.cloudflare.com/ → Turnstile → Add site
# Leave blank in dev — uses test key (always passes)
TURNSTILE_SECRET_KEY=
